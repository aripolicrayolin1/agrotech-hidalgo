
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del agricultor.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "location": { "type": "string" },
        "cropType": { "type": "string" }
      },
      "required": ["email"]
    },
    "Farm": {
      "title": "Finca",
      "description": "Datos de un terreno monitoreado.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "crop": { "type": "string" },
        "area": { "type": "string" },
        "userId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos de perfil del usuario"
    },
    "/users/{userId}/farms/{farmId}": {
      "schema": "Farm",
      "description": "Fincas registradas por el usuario"
    }
  }
}
